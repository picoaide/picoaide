{
  "manifest_version": 3,
  "name": "PicoAide Helper",
  "version": "2.0.0",
  "description": "同步网站登录凭据到 PicoAide",
  "permissions": ["storage", "cookies", "activeTab", "scripting", "tabs", "tabGroups", "offscreen"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
